# 复制为 .env 并填写你的配置

# ── 智谱 API（推荐，国内直连）──
ZHIPU_API_KEY=your-zhipu-api-key-here
# ZHIPU_MODEL=glm-4-flash

# ── 或 OpenAI 兼容 API ──
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# ── 定时任务（本地 scheduler 用，GitHub Actions 走 cron）──
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# ── 抓取 ──
MAX_PAPERS_PER_SOURCE=30
PAPER_KEYWORDS=LLM,Agent,Memory,RAG,Tool Use,Function Calling,Planning,Reasoning,Multi-Agent,Autonomous
TOP_K_PAPERS=10

# 用户画像（LLM 精选和总结时参考）
# USER_PROFILE=工业界 Agent 算法工程师，关注 LLM Agent / 多智能体 / 工具调用 / 记忆机制 / RAG / 推理规划等方向

# ── 企业微信群机器人 Webhook ──
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here
